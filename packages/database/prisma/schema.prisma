generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  name               String?
  role               String          @default("OWNER") // "OWNER" or "AGENT"
  
  clientProfile      Client?
  
  // Relations
  properties         Property[]      @relation("OwnerProperties")
  assignedProperties PropertyAgent[]
}

enum ClientStatus {
  PROPRIETAIRE
  ACQUEREUR
  BAILLEUR
  LOCATAIRE
}

enum ClientGender {
  HOMME
  FEMME
  AUTRE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  OTHER
}

model Client {
  id                   String          @id @default(cuid())
  userId               String?         @unique
  user                 User?           @relation(fields: [userId], references: [id])
  
  isActive             Boolean         @default(true)

  status               ClientStatus[]
  gender               ClientGender?
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  placeOfBirth         String?
  maritalStatus        MaritalStatus?
  
  addressId            Int?
  address              String?
  mobilePhone          String?
  primaryEmail         String          
  secondaryEmail       String?
  
  jobTitle             String?
  incomeBracket        String? // (e.g., "80 000 à 120 000 euros Brut / an")
  
  kbisUrl              String?
  cniUrl               String?
  passportUrl          String?
  
  // Specific - Owner / Bailleur
  totalOwnedProperties     String? 
  propertiesForSaleCount   String?
  titleDeedUrl             String?
  propertiesUnderMgmtCount String?
  
  // Specific - Acquéreur / Locataire
  paySlipUrl               String?
  taxStatementUrl          String?
  loanOfferUrl             String?
  
  // Relations
  properties           Property[]      @relation("ClientProperties")
  deals                Deal[]
  loanAnalyses         LoanAnalysis[]
  
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

enum DealType {
  VENTE
  BAIL
  ACQUISITION
  LOCATION
}

enum DealStatus {
  VENTE_ATTENTE_MANDAT
  VENTE_MANDAT_EDITE
  VENTE_MANDAT_SIGNE_ANNONCE_EDITEE
  VENTE_MANDAT_SIGNE_ANNONCE_PUBLIEE_VISITES_PROGRAMMEES
  VENTE_MANDAT_SIGNE_ANNONCE_PUBLIEE_VISITES_EFFECTUEES_PROMESSE
  VENTE_MANDAT_SIGNE_ANNONCE_PUBLIEE_VISITES_EFFECTUEES_NOTAIRE
  BAIL_ATTENTE_MANDAT
  BAIL_MANDAT_SIGNE
  ACQUISITION_RECHERCHE
  LOCATION_RECHERCHE
  OTHER
}

model Deal {
  id          String     @id @default(cuid())
  clientId    String
  propertyId  String?
  type        DealType   @default(VENTE) 
  status      DealStatus @default(VENTE_ATTENTE_MANDAT) 
  
  client      Client     @relation(fields: [clientId], references: [id])
  property    Property?  @relation(fields: [propertyId], references: [id])
  
  saleAnalyses SaleAnalysis[]
  loanAnalyses LoanAnalysis[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum PropertyType {
  STUDIO
  T1
  T2
  T3
  T4
  MAISON_DE_VILLE
  OTHER
}

enum PropertyStatus {
  OFF_MARKET
  A_VENDRE
  A_LOUER
  LOUER
  VENDU
  OTHER
}

model Property {
  id             String               @id @default(cuid())
  address        String
  
  type           PropertyType         @default(OTHER)
  status         PropertyStatus       @default(OFF_MARKET)
  
  ownerId        String?
  owner          User?                 @relation("OwnerProperties", fields: [ownerId], references: [id])
  
  clientId       String?
  client         Client?               @relation("ClientProperties", fields: [clientId], references: [id])
  
  assignedAgents PropertyAgent[] 
  maintenanceLogs MaintenanceLog[]
  documents       Document[]
  triggers        OpportunityTrigger[]
  deals           Deal[]
  saleAnalyses    SaleAnalysis[]
}

// Map table to handle independence and multi-agent
model PropertyAgent {
  id              String   @id @default(cuid())
  propertyId      String
  agentId         String
  property        Property @relation(fields: [propertyId], references: [id])
  agent           User     @relation(fields: [agentId], references: [id])
  
  // Permissions: what can the agent see?
  canSeeEstimations Boolean @default(true)
  canSeeTriggers    Boolean @default(true)
  
  createdAt       DateTime @default(now())
  @@unique([propertyId, agentId])
}

model MaintenanceLog {
  id            String   @id @default(cuid())
  category      String   
  description   String
  amount        Float?
  isPrivate     Boolean  @default(true) // If TRUE, the agent only sees the type of action
  
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id])
}

model OpportunityTrigger {
  id            String   @id @default(cuid())
  type          String   // "RENO_DETECTED", "DPE_ALERT"
  description   String   // Anonymized text for the agent (e.g., "Travaux de valorisation détectés")
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id])
  // We do not link the trigger to a specific agent here, but to the property
}

// Basic Document model to ensure schema validity
model Document {
  id          String   @id @default(cuid())
  title       String
  url         String
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
}

model SaleAnalysis {
  id             String    @id @default(cuid())
  propertyId     String
  dealId         String?
  
  estimatedValue Float?
  targetPrice    Float?
  finalPrice     Float?
  
  notes          String    @default("")
  
  property       Property  @relation(fields: [propertyId], references: [id])
  deal           Deal?     @relation(fields: [dealId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model LoanAnalysis {
  id             String    @id @default(cuid())
  clientId       String
  dealId         String?
  
  maxLoanAmount  Float?
  interestRate   Float?
  durationMonths Int?
  monthlyPayment Float?
  
  bankName       String?
  status         String    @default("PENDING") // e.g., PENDING, APPROVED, REJECTED
  
  client         Client    @relation(fields: [clientId], references: [id])
  deal           Deal?     @relation(fields: [dealId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
