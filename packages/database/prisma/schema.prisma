  // Pipeline commercial
  infoRequestsCount   Int?
  visitCount          Int?
  lastVisitDate       DateTime?
  purchaseOfferStatus PurchaseOfferStatus?
  purchaseOfferDate   DateTime?
  purchaseOfferAmount Float?
  notarialDeedStatus  NotarialDeedStatus?
  notarialDeedDate    DateTime?
  finalSalePrice      Float?

  // Acquisition
  acquisitionMinBudget       Float?
  acquisitionMaxBudget       Float?
  acquisitionCriteriaSummary String?
  acquisitionFinancingExpiry DateTime?

  // Bail
  bailType          BailType?
  bailMonthlyRent   Float?
  bailCharges       Float?
  bailDepositAmount Float?
  bailSignedDate    DateTime?
  bailStartDate     DateTime?
  bailEndDate       DateTime?

  // Location
  locationMinBudget       Float?
  locationCriteriaSummary String?

  // Pipeline
  pipelineStage   PipelineStage? @default(PROSPECT)
  stageChangedAt  DateTime?
  conversionSource String?
  currentMilestone String?

  // Reverse relations
  saleAnalyses        SaleAnalysis[]
  loanAnalyses        LoanAnalysis[]
  financing           ClientFinancing[]    @relation("FinancingDeal")
  triggers            Trigger[]
  messages            Message[]
  events              Event[]
  documents           Document[]           @relation("DealDocuments")
  mandateSignals      MandateSignal[]
  dealMilestoneEvents DealMilestoneEvent[]
  playbookEnrollments PlaybookEnrollment[]
  propertyMatches     PropertyMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

