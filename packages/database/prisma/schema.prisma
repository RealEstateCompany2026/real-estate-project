  conversionDeal   Deal?            @relation(fields: [conversionDealId], references: [id])
  stepHistory      Json?            @default("[]")

  createdAt DateTime @default(now())
}

// ── Segmentation & Engagement ─────────────────────────────────────────────────

model ClientSegment {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id])

  temperatureScore   Int?         @default(0)
  segment            SegmentType  @default(INCONNU)
  previousSegment    SegmentType?
  segmentChangedAt   DateTime?
  lastInteractionAt  DateTime?
  lastEngagementAt   DateTime?
  engagementCount30d Int?         @default(0)
  identifiedProject  IdentifiedProject? @default(INCONNU)
  dataQualityScore   Int?         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model ClientEngagementSignal {
  id         String @id @default(uuid())
  clientId   String
  client     Client @relation(fields: [clientId], references: [id])
  agentId    String
  agent      Agent  @relation(fields: [agentId], references: [id])

  signalType            EngagementSignalType
  source                String?
  scoreImpact           Int?     @default(0)
  metadata              Json?
  triggersMandateSignal  Boolean? @default(false)

  createdAt DateTime @default(now())
}

model SegmentTransition {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id])

  fromSegment        SegmentType?
  toSegment          SegmentType
  fromScore          Int?
  toScore            Int?
  triggerType        SegmentTransitionTrigger
  triggerReferenceId String?

  createdAt DateTime @default(now())
}

// ── Agent-Client Link ─────────────────────────────────────────────────────────

model AgentClientLink {
  id               String   @id @default(uuid())
  ownerAccountId   String
  agentId          String
  agent            Agent    @relation(fields: [agentId], references: [id])
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  crmClientId      String?
  crmClient        Client?  @relation(fields: [crmClientId], references: [id])

  status               AgentClientLinkStatus @default(PENDING_INVITATION)
  source               AgentClientLinkSource @default(AGENT_INVITATION)
  startDate            DateTime?             @default(now())
  endDate              DateTime?
  isDataSharingConsented Boolean?             @default(false)
  consentDate          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

// ── Subscription ──────────────────────────────────────────────────────────────

model Subscription {
  id             String   @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  agentId        String?
  agent          Agent?   @relation(fields: [agentId], references: [id])

  plan                  SubscriptionPlan   @default(TRIAL)
  status                SubscriptionStatus @default(TRIALING)
  trialStartDate        DateTime?
  trialEndDate          DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  maxAgents             Int?               @default(1)
  maxProperties         Int?               @default(50)
  features              Json?              @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

// ── Data Quality ──────────────────────────────────────────────────────────────

model AuditScore {
  id             String   @id @default(uuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  globalScore       Int?      @default(0)
  completenessScore Int?      @default(0)
  consistencyScore  Int?      @default(0)
  freshnessScore    Int?      @default(0)
  duplicatesScore   Int?      @default(0)
  calculatedAt      DateTime  @default(now())
  details           Json?

  createdAt DateTime @default(now())
}

model ScoringConfig {
  id         String  @id @default(uuid())
  metricKey  String
  version    String  @default("2026-04-v1")
  isActive   Boolean @default(true)
  entityType String
  formula    Json
  weights    Json?
  thresholds Json?
  description String?

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now())
}

model DuplicatePair {
  id             String   @id @default(uuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id])

  entityType      DuplicateEntityType
  entityAId       String
  entityBId       String
  confidenceScore Int?              @default(0)
  matchingFields  Json?
  status          DuplicateStatus   @default(DETECTED)
  mergedIntoId    String?

  createdAt DateTime @default(now())
}

model EmailPreference {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id])

  globalOptout      Boolean           @default(false)
  optoutCategories  Json?             @default("{}")
  maxFrequency      MaxEmailFrequency? @default(MONTHLY)
  unsubscribedAt    DateTime?
  unsubscribeReason String?
  resubscribedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

// ── Import & Integration ──────────────────────────────────────────────────────

model ImportJob {
  id             String   @id @default(uuid())
  agentId        String?
  agent          Agent?   @relation(fields: [agentId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  fileUrl       String?
  fileName      String?
  fileFormat    ImportFileFormat?
  entityType    ImportEntityType?
  mappingConfig Json?
  status        ImportStatus     @default(PENDING)
  totalRows     Int?             @default(0)
  importedRows  Int?             @default(0)
  errorRows     Int?             @default(0)
  errorLog      Json?
  duplicateRows Int?             @default(0)
  startedAt     DateTime?
  completedAt   DateTime?

  createdAt DateTime @default(now())
}

model Integration {
  id             String   @id @default(uuid())
  agentId        String?
  agent          Agent?   @relation(fields: [agentId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  connectorType       ConnectorType
  status              IntegrationStatus   @default(DISCONNECTED)
  authType            AuthType?
  credentialsVaultId  String?
  config              Json?               @default("{}")
  syncMode            SyncMode?           @default(PERIODIC)
  syncIntervalMinutes Int?                @default(60)
  lastSyncAt          DateTime?
  lastError           String?
  errorCount          Int?                @default(0)

  // Reverse relations
  fieldMappings      FieldMapping[]
  syncLogs           SyncLog[]
  portalPublications PortalPublication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model FieldMapping {
  id            String      @id @default(uuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id])

  entityType      MappingEntityType
  localField      String
  externalField   String
  transformRule   TransformRule?    @default(NONE)
  transformConfig Json?
  isActive        Boolean           @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model SyncLog {
  id            String      @id @default(uuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id])
  agentId       String?
  agent         Agent?      @relation(fields: [agentId], references: [id])

  direction    SyncDirection
  entityType   SyncEntityType
  entityId     String?
  externalId   String?
  action       SyncAction
  status       SyncStatus
  changesDiff  Json?
  errorMessage String?
  durationMs   Int?

  createdAt DateTime @default(now())
}
