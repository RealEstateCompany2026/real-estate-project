// ── Core ──────────────────────────────────────────────────────────────────────

model User {
  id          String  @id
  email       String  @unique
  name        String?
  role        String  @default("AGENT")
  supabase_id String? @db.Uuid

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Reverse relations
  agents             Agent[]
  clientProfile      Client?           @relation("ClientUser")
  ownedProperties    Property[]        @relation("OwnerProperties")
  assignedProperties PropertyAgent[]
  managedClients     Client[]          @relation("AgentClients")
  managedDeals       Deal[]            @relation("AgentDeals")
  managedTriggers    Trigger[]         @relation("AgentTriggers")
  sentMessages       Message[]         @relation("AgentMessages")
  managedEvents      Event[]           @relation("AgentEvents")
  uploadedDocuments  Document[]        @relation("UploadedDocuments")
  createdMilestones  DealMilestoneEvent[]
  propertyShareLinks PropertyShareLink[] @relation("ShareLinkCreator")
  propertyMedia      PropertyMedia[]     @relation("MediaUploader")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Organization {
  id   String @id @default(uuid())
  name String

  siret           String?
  address         String?
  phone           String?
  email           String?
  logoUrl         String?
  network         NetworkType?
  carteTNumber    String?
  carteGNumber    String?
  rcpInsuranceRef String?
  rcpExpiryDate   DateTime?    @db.Date
  maxAgents       Int?         @default(5)
  invitationCode  String?

  // Reverse relations
  users              User[]
  agents             Agent[]
  clients            Client[]
  properties         Property[]
  deals              Deal[]
  messages           Message[]
  triggers           Trigger[]
  events             Event[]
  documents          Document[]
  listings           Listing[]
  campaigns          Campaign[]
  notifications      Notification[]
  subscriptions      Subscription[]
  agentClientLinks   AgentClientLink[]
  importJobs         ImportJob[]
  integrations       Integration[]
  auditScores        AuditScore[]
  propertyShareLinks PropertyShareLink[]
  propertyMedia      PropertyMedia[]
  leads              Lead[]
  playbooks          Playbook[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Agent {
  id             String  @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])

  language               String?        @default("fr")
  firstName              String
  lastName               String
  email                  String
  mobilePhone            String?
  avatarUrl              String?
  specialty              AgentSpecialty?
  rsacNumber             String?
  orgRole                OrgRole        @default(AGENT)
  accountStatus          AccountStatus  @default(TRIAL)
  trialEndsAt            DateTime?
  notificationPreferences Json?         @default("{}")
  timezone               String?        @default("Europe/Paris")
  lastLoginAt            DateTime?
  onboardingCompleted    Boolean        @default(false)
  onboardingStep         OnboardingStep? @default(WELCOME)

  // Reverse relations
  propertyAgents         Property[]              @relation("PropertyAgent")
  agentClientLinks       AgentClientLink[]
  clientEngagementSignals ClientEngagementSignal[]
  clientSegments         ClientSegment[]
  mandateSignalsOwned    MandateSignal[]          @relation("MandateSignalAgent")
  mandateSignalsAssigned MandateSignal[]          @relation("MandateSignalAssignee")
  signalActions          SignalAction[]
  segmentTransitions     SegmentTransition[]
  campaigns              Campaign[]
  campaignSends          CampaignSend[]
  playbooks              Playbook[]
  playbookEnrollments    PlaybookEnrollment[]
  listings               Listing[]
  notifications          Notification[]
  subscriptions          Subscription[]
  leads                  Lead[]
  portalPublications     PortalPublication[]
  auditScores            AuditScore[]
  duplicatePairs         DuplicatePair[]
  emailPreferences       EmailPreference[]
  importJobs             ImportJob[]
  integrations           Integration[]
  syncLogs               SyncLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

// ── Client ────────────────────────────────────────────────────────────────────

model Client {
  id     String  @id
  userId String? @unique
  user   User?   @relation("ClientUser", fields: [userId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  agentId String?
  agent   User?   @relation("AgentClients", fields: [agentId], references: [id])

  isActive Boolean @default(true)

  // Profil
  status        ClientStatus[]
  gender        ClientGender?
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  placeOfBirth  String?
  nationality   String?
  maritalStatus MaritalStatus?

  // Contact
  address          String?
  mobilePhone      String?
  primaryEmail     String
  secondaryEmail   String?
  preferredChannel PreferredChannel?

  // Professionnel
  jobTitle      String?
  incomeBracket String?
  employer      String?
  siren         String?

  // Scoring IA
  reactivationScore  Int?
  qualificationScore Int?
  triggerCount       Int?

  // Documents KYC
  kbisUrl            String?
  cniUrl             String?
  passportUrl        String?
  cniExpiryDate      DateTime?
  passportExpiryDate DateTime?

  // Proprietaire / Bailleur
  totalOwnedProperties     Int?
  propertiesForSaleCount   Int?
  titleDeedUrl             String?
  propertiesUnderMgmtCount Int?

  // Acquereur / Locataire
  paySlipUrl            String?
  taxStatementUrl       String?
  loanOfferUrl          String?
  financingExpiryDate   DateTime?
  searchCriteriaSummary String?

  // Misc
  notes              String?
  source             ClientSource?
  language           String?  @default("fr")
  emailConsent       Boolean? @default(false)
  emailConsentSource String?
  emailConsentDate   DateTime?
  lifecycleStage     String?  @default("lead")
  tags               Json?    @default("[]")
  isPotentialDuplicate Boolean? @default(false)
  completionScore    Int?     @default(0)

  // Reverse relations
  properties              Property[]              @relation("ClientProperties")
  deals                   Deal[]
  financing               ClientFinancing[]
  loanAnalyses            LoanAnalysis[]
  fiscalDetails           PropertyFiscalDetails[]
  messages                Message[]
  triggers                Trigger[]
  events                  Event[]
  documents               Document[]
  agentClientLinks        AgentClientLink[]
  clientPastTransactions  ClientPastTransaction[]
  clientSegments          ClientSegment[]
  clientEngagementSignals ClientEngagementSignal[]
  mandateSignals          MandateSignal[]
  campaignSends           CampaignSend[]
  playbookEnrollments     PlaybookEnrollment[]
  leads                   Lead[]
  emailPreferences        EmailPreference[]
  segmentTransitions      SegmentTransition[]
  visitGuideResponses     VisitGuideResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Property ──────────────────────────────────────────────────────────────────

model Property {
  id String @id

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  ownerId  String?
  owner    User?   @relation("OwnerProperties", fields: [ownerId], references: [id])
  clientId String?
  client   Client? @relation("ClientProperties", fields: [clientId], references: [id])
  agentId  String?
  agent    Agent?  @relation("PropertyAgent", fields: [agentId], references: [id])

  coOwnershipId String?
  coOwnership   CoOwnershipDetails? @relation("PropertyCoOwnership", fields: [coOwnershipId], references: [id])

  listingId String?
  listing   Listing? @relation("PropertyListingRef", fields: [listingId], references: [id])

  referencePropertyId String?

  // Type & statut
  type      PropertyType      @default(OTHER)
  status    PropertyStatus    @default(OFF_MARKET)
  condition PropertyCondition?

  // Localisation
  address          String
  addressStreet    String?
  addressZipCode   String?
  addressCity      String?
  addressLat       Float?
  addressLng       Float?
  neighborhoodName String?

  // Structure
  constructionYear  Int?
  floorLevel        Int?
  numberOfFloors    Int?
  hasElevator       Boolean?
  hasIntercom       Boolean?
  hasHomeAutomation Boolean?

  // Surfaces
  livingAreaSqm   Float?
  landAreaSqm     Float?
  numberOfRooms   Int?
  mainRoomAreaSqm Float?
  bedroomCount    Int?
  bedroom1AreaSqm Float?
  bedroom2AreaSqm Float?
  bedroom3AreaSqm Float?
  bedroom4AreaSqm Float?
  kitchenAreaSqm  Float?
  kitchenType     KitchenType?
  bathroomCount   Int?
  showerRoomCount Int?
  toiletCount     Int?
  terraceAreaSqm  Float?
  balconyAreaSqm  Float?
  gardenAreaSqm   Float?
  basementAreaSqm Float?
  atticAreaSqm    Float?

  // Equipements
  parkingType      ParkingType?
  parkingSpotCount Int?
  heatingType      HeatingType?
  hotWaterSystem   HotWaterSystem?
  hasPool          Boolean?
  poolType         PoolType?

  // Exposition & vue
  mainExposure Exposure?
  mainViewType ViewType?
  exposures    Exposure[]

  // DPE
  dpeEnergyClass        DpeClass?
  dpeGasEmissionClass   DpeClass?
  dpeEnergyKwh          Float?
  dpeGasGco2            Float?
  dpeValidityDate       DateTime?
  dpeComplianceDeadline DateTime?

  // Valeur & annonce
  estimatedMarketValue       Float?
  estimatedMarketValuePerSqm Float?
  desiredSellingPrice        Float?
  listingStatus              ListingStatus?
  listingPublicationDate     DateTime?

  // Entretien
  hasMaintenanceLog          Boolean?
  maintenanceLogCreationDate DateTime?
  lastMaintenanceDate        DateTime?

  // Proximite
  proximityToShops     Boolean?
  proximityToSchools   Boolean?
  proximityToDaycares  Boolean?
  proximityToTransport Boolean?
  proximityToHighways  Boolean?

  // Completion
  completionScore         Int?   @default(0)
  completionMissingFields Json?

  // Misc
  internalRef    String?
  notes          String?
  tags           Json?           @default("[]")
  operationTypes OperationType[]

  // Reverse relations
  assignedAgents                  PropertyAgent[]
  maintenanceLogs                 MaintenanceLog[]
  coOwnershipDetails              CoOwnershipDetails[]           @relation("CoOwnershipProperty")
  fiscalDetails                   PropertyFiscalDetails[]
  deals                           Deal[]
  financing                       ClientFinancing[]
  saleAnalyses                    SaleAnalysis[]
  messages                        Message[]
  triggers                        Trigger[]
  events                          Event[]
  documents                       Document[]
  mandateSignals                  MandateSignal[]
  clientPastTransactions          ClientPastTransaction[]
  opportunityTriggers             OpportunityTrigger[]
  propertyDiagnosticQuestionnaires PropertyDiagnosticQuestionnaire[]
  propertyFeatures                PropertyFeature[]
  propertyShareLinks              PropertyShareLink[]
  propertyMedia                   PropertyMedia[]
  listings                        Listing[]                      @relation("ListingProperty")
  availabilityExceptions          PropertyAvailabilityException[]
  propertyMatches                 PropertyMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model PropertyAgent {
  id         String   @id
  propertyId String
  agentId    String
  property   Property @relation(fields: [propertyId], references: [id])
  agent      User     @relation(fields: [agentId], references: [id])

  canSeeEstimations Boolean @default(true)
  canSeeTriggers    Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([propertyId, agentId])
